{
  "audit_metadata": {
    "project": "AA-U1 Auditoría Económica Aplicada",
    "subject_country": "South Korea (KOR)",
    "period": "1980-2020",
    "generation_date": "2026-04-24",
    "data_fidelity_level": 5,
    "lineage": {
      "sources": [
        {
          "name": "Penn World Table 11.0",
          "local_path": "applied_econometrics_2026/data/raw/externos/pwt110.xlsx",
          "variables_extracted": ["rgdpna", "pop", "hc", "countrycode"],
          "link": "https://www.rug.nl/ggdc/productivity/pwt/"
        },
        {
          "name": "World Bank API",
          "indicators": [
            {
              "id": "TX.VAL.MANF.ZS.UN",
              "alias": "manuf_exports_raw",
              "description": "Manufactures exports (% of merchandise exports)",
              "link": "https://data.worldbank.org/indicator/TX.VAL.MANF.ZS.UN"
            },
            {
              "id": "TT.PRI.MRCH.XD.WD",
              "alias": "terms_of_trade_raw",
              "description": "Net barter terms of trade index (2015 = 100)",
              "link": "https://data.worldbank.org/indicator/TT.PRI.MRCH.XD.WD"
            }
          ]
        }
      ],
      "transformations": [
        {
          "step": 1,
          "action": "Filtering",
          "criteria": "countrycode == 'KOR' AND year BETWEEN 1980 AND 2020"
        },
        {
          "step": 2,
          "action": "Calculation",
          "variable": "gdp_pc",
          "formula": "rgdpna / pop",
          "description": "Real GDP per capita calculation at 2017 constant national prices."
        },
        {
          "step": 3,
          "action": "Merging",
          "method": "Left Join on 'year'",
          "description": "Consolidation of PWT 11.0 local series with dynamic World Bank indicators."
        },
        {
          "step": 4,
          "action": "Documentation",
          "component": "Dictionary Sheet",
          "details": "Added columns: Variable, Descripción, Tipo de dato, Fuente, Link."
        }
      ]
    },
    "technical_stack": {
      "language": "Python 3.12",
      "libraries": ["pandas", "openpyxl", "requests"],
      "environment_manager": "uv"
    },
    "output_file": "data/raw/KOR_Audit_Data.xlsx",
    "output_sheets": ["MainData", "Diccionario"]
  }
}
