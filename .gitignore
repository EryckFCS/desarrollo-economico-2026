# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info
.coverage
htmlcov/
.pytest_cache/

# Virtual environments
.venv

# Quarto
/.quarto/
**/*.quarto_ipynb*
**/*_files/
**/*_cache/
_site/
_freeze/

# Project data artifacts
data/*
!data/.gitkeep
scratch/*
!scratch/.gitkeep
reports/*
!reports/.gitkeep

# Archives and Large Files
*.zip
*.tar.gz
*.rar
*.7z

# Specific Exclusions
Photos*/
render_log*.txt

# PDFs generados (evidencia PDF sí se versiona en docs/)
*.pdf
!docs/**/*.pdf
.ipynb_checkpoints/
.ruff_cache/

# Heavy Data Exclusion (Vaults Architecture)
docs/vaults/**/data/*.csv
docs/vaults/**/data/*.parquet
docs/vaults/**/data/*.xlsx
docs/vaults/**/data/*.dta
docs/vaults/**/data/*.sav
docs/vaults/**/data/*.db
docs/vaults/**/data/*.sqlite

**/*.quarto_ipynb
